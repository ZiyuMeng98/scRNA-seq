# ======== 细胞类型注释 ========
print("\n" + "="*60)
print("细胞类型注释（一级注释）")
print("="*60)

# 定义小鼠心脏组织的主要细胞类型marker基因
marker_genes = {
    'Cardiomyocytes': ['Tnnt2', 'Myh6', 'Myh7', 'Actc1', 'Ryr2'],  # 心肌细胞
    'Fibroblasts': ['Col1a1', 'Col1a2', 'Col3a1', 'Dcn', 'Lum', 'Pdgfra'],  # 成纤维细胞
    'Endothelial': ['Pecam1', 'Cdh5', 'Vwf', 'Eng', 'Kdr'],  # 内皮细胞
    'Smooth Muscle': ['Acta2', 'Myh11', 'Tagln', 'Cnn1'],  # 平滑肌细胞
    'Macrophages': ['Cd68', 'Adgre1', 'C1qa', 'C1qb', 'C1qc'],  # 巨噬细胞
    'Monocytes': ['Ly6c2', 'Ccr2', 'Cx3cr1'],  # 单核细胞
    'T cells': ['Cd3d', 'Cd3e', 'Cd3g', 'Cd8a', 'Cd4'],  # T细胞
    'B cells': ['Cd79a', 'Ms4a1', 'Cd19'],  # B细胞
    'NK cells': ['Nkg7', 'Klrb1c', 'Klrd1'],  # NK细胞
    'Neutrophils': ['S100a8', 'S100a9', 'Cxcr2'],  # 中性粒细胞
    'Mast cells': ['Cpa3', 'Mcpt4', 'Kit'],  # 肥大细胞
    'Erythrocytes': ['Hba-a1', 'Hbb-bs', 'Hbb-bt'],  # 红细胞
    'Proliferating': ['Mki67', 'Pcna', 'Top2a']  # 增殖细胞
}

# 检查哪些marker基因在你的数据中存在
print("检查marker基因在数据中的存在情况...")
available_markers = {}
for cell_type, genes in marker_genes.items():
    available_genes = [gene for gene in genes if gene in adata.var_names]
    if available_genes:
        available_markers[cell_type] = available_genes
        print(f"  {cell_type}: {len(available_genes)}/{len(genes)} 个基因存在")
    else:
        print(f"  ⚠️ {cell_type}: 无可用marker基因")

# 绘制marker基因点图
print("\n生成marker基因点图...")

# 选择每个细胞类型的前3个可用基因用于点图
dotplot_genes = []
for cell_type, genes in available_markers.items():
    dotplot_genes.extend(genes[:3])

if dotplot_genes:
    fig, ax = plt.subplots(figsize=(12, 8))
    sc.pl.dotplot(
        adata,
        var_names=dotplot_genes,
        groupby='cluster',
        ax=ax,
        show=False,
        cmap='RdBu_r',
        standard_scale='var',
        dendrogram=True
    )
    plt.tight_layout()
    plt.savefig('marker_gene_dotplot.png', dpi=300, bbox_inches='tight')
    plt.close()
    print("✅ marker基因点图已保存")
else:
    print("⚠️ 无可用marker基因用于点图")

# 绘制marker基因在小提琴图中的表达
print("\n生成marker基因小提琴图...")

# 选择关键细胞类型的代表性基因
key_genes = ['Tnnt2', 'Col1a1', 'Pecam1', 'Cd68', 'Cd3d', 'Cd79a']
key_genes = [gene for gene in key_genes if gene in adata.var_names]

if key_genes:
    fig, axes = plt.subplots(2, 3, figsize=(15, 10))
    axes = axes.flatten()
    
    for i, gene in enumerate(key_genes[:6]):
        sc.pl.violin(adata, gene, groupby='cluster', ax=axes[i], show=False)
        axes[i].set_title(f'{gene} expression')
        axes[i].tick_params(axis='x', rotation=45)
    
    plt.suptitle('关键marker基因在各聚类中的表达', fontsize=16, y=1.02)
    plt.tight_layout()
    plt.savefig('marker_gene_violin.png', dpi=150, bbox_inches='tight')
    plt.close()
    print("✅ marker基因小提琴图已保存")

# ======== 自动化细胞类型注释 ========
print("\n" + "="*60)
print("自动化细胞类型注释")
print("="*60)

# 方法1：基于marker基因评分
print("方法1: 基于marker基因评分进行注释...")

from scipy import stats

def annotate_by_marker_scores(adata, marker_dict, min_score=0.3):
    """基于marker基因评分进行细胞类型注释"""
    
    # 为每个细胞类型计算平均表达
    cell_type_scores = {}
    
    for cell_type, genes in marker_dict.items():
        available_genes = [g for g in genes if g in adata.var_names]
        if len(available_genes) >= 2:  # 至少需要2个基因
            # 计算该细胞类型在所有细胞中的平均表达
            expr_matrix = adata[:, available_genes].X
            if hasattr(expr_matrix, 'toarray'):
                expr_matrix = expr_matrix.toarray()
            
            # 计算每个细胞的平均表达（z-score标准化）
            cell_scores = expr_matrix.mean(axis=1)
            cell_scores_z = stats.zscore(cell_scores)
            
            cell_type_scores[cell_type] = cell_scores_z
    
    if not cell_type_scores:
        print("⚠️ 无足够marker基因进行评分")
        return adata
    
    # 为每个细胞分配最可能的细胞类型
    cell_type_names = list(cell_type_scores.keys())
    score_matrix = np.column_stack([cell_type_scores[ct] for ct in cell_type_names])
    
    # 找到每个细胞的最高分
    max_scores = score_matrix.max(axis=1)
    best_types = np.argmax(score_matrix, axis=1)
    
    # 创建注释列
    adata.obs['predicted_celltype'] = 'Unknown'
    adata.obs['prediction_score'] = 0.0
    
    for i in range(len(adata)):
        if max_scores[i] >= min_score:
            adata.obs.iloc[i, adata.obs.columns.get_loc('predicted_celltype')] = cell_type_names[best_types[i]]
            adata.obs.iloc[i, adata.obs.columns.get_loc('prediction_score')] = max_scores[i]
    
    return adata

# 运行自动化注释
adata = annotate_by_marker_scores(adata, available_markers, min_score=0.5)

# 查看注释结果
print("\n细胞类型注释统计:")
celltype_counts = adata.obs['predicted_celltype'].value_counts()
print(celltype_counts)

# 将注释结果映射到聚类
print("\n各聚类的细胞类型组成:")
for cluster in sorted(adata.obs['cluster'].unique()):
    cluster_mask = adata.obs['cluster'] == cluster
    cluster_celltypes = adata.obs.loc[cluster_mask, 'predicted_celltype'].value_counts()
    if len(cluster_celltypes) > 0:
        main_type = cluster_celltypes.index[0]
        main_percent = cluster_celltypes.iloc[0] / cluster_mask.sum() * 100
        print(f"  聚类 {cluster}: 主要类型 = {main_type} ({main_percent:.1f}%)")

# 保存注释结果
adata.write('adata_with_celltype_annotations.h5ad')
print("✅ 保存带细胞类型注释的数据")

# ======== 手动验证标记基因表达 ========
print("\n" + "="*60)
print("手动验证关键细胞类型的marker基因表达")
print("="*60)

# 选择要验证的关键细胞类型
key_celltypes_to_check = ['Cardiomyocytes', 'Fibroblasts', 'Endothelial', 'Macrophages']

for celltype in key_celltypes_to_check:
    if celltype in available_markers:
        print(f"\n验证 {celltype} 的marker基因表达:")
        markers = available_markers[celltype][:3]  # 取前3个基因
        
        # 筛选属于该细胞类型的细胞
        celltype_mask = adata.obs['predicted_celltype'] == celltype
        if celltype_mask.sum() > 0:
            # 创建子图
            fig, axes = plt.subplots(1, 3, figsize=(15, 4))
            
            for i, gene in enumerate(markers):
                if gene in adata.var_names:
                    # 在该细胞类型中的表达
                    celltype_adata = adata[celltype_mask]
                    expr_values = celltype_adata[:, gene].X
                    if hasattr(expr_values, 'toarray'):
                        expr_values = expr_values.toarray().flatten()
                    
                    # 绘制直方图
                    axes[i].hist(expr_values, bins=30, alpha=0.7, color='skyblue')
                    axes[i].set_xlabel('表达量')
                    axes[i].set_ylabel('细胞数')
                    axes[i].set_title(f'{gene} 在 {celltype} 中的表达')
                    axes[i].grid(True, alpha=0.3)
                    
                    # 计算表达统计
                    mean_expr = expr_values.mean()
                    expr_percent = (expr_values > 0).mean() * 100
                    axes[i].text(0.05, 0.95, f'平均: {mean_expr:.2f}\n表达率: {expr_percent:.1f}%', 
                               transform=axes[i].transAxes, verticalalignment='top',
                               bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
            
            plt.suptitle(f'{celltype} marker基因表达验证', fontsize=14, y=1.05)
            plt.tight_layout()
            plt.savefig(f'{celltype.lower()}_marker_validation.png', dpi=150, bbox_inches='tight')
            plt.close()
            print(f"✅ {celltype} marker验证图已保存")
        else:
            print(f"  ⚠️ 未找到预测为 {celltype} 的细胞")

# 生成综合报告
print("\n" + "="*60)
print("细胞类型注释完成总结")
print("="*60)

print(f"\n1. 数据基本信息:")
print(f"   总细胞数: {adata.n_obs}")
print(f"   聚类数: {len(adata.obs['cluster'].unique())}")
print(f"   预测的细胞类型数: {len(adata.obs['predicted_celltype'].unique())}")

print(f"\n2. 细胞类型分布:")
for celltype, count in adata.obs['predicted_celltype'].value_counts().items():
    percent = count / adata.n_obs * 100
    print(f"   {celltype}: {count} 细胞 ({percent:.1f}%)")

print(f"\n3. 主要细胞类型的聚类对应关系:")
# 找出每个聚类的主要细胞类型
cluster_celltype_summary = {}
for cluster in sorted(adata.obs['cluster'].unique()):
    cluster_mask = adata.obs['cluster'] == cluster
    cluster_types = adata.obs.loc[cluster_mask, 'predicted_celltype'].value_counts()
    if len(cluster_types) > 0:
        main_type = cluster_types.index[0]
        main_count = cluster_types.iloc[0]
        main_percent = main_count / cluster_mask.sum() * 100
        cluster_celltype_summary[cluster] = (main_type, main_percent)
        if main_percent > 50:  # 只显示纯度>50%的聚类
            print(f"   聚类 {cluster}: {main_type} ({main_percent:.1f}%)")

print(f"\n4. 下一步建议:")
print("   a. 检查标记基因表达图，验证注释准确性")
print("   b. 对混合度高的聚类进行人工复核")
print("   c. 提取主要细胞类型进行子聚类分析")
print("   d. 进行批次整合（如果批次效应明显）")

# 保存最终结果
adata.write('adata_final_annotated.h5ad')
print("\n✅ 最终注释数据已保存: adata_final_annotated.h5ad")
print("✅ 细胞类型注释步骤完成！")
