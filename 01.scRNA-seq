# 质控和过滤
# 以下在python3.8.4环境进行
import matplotlib
matplotlib.use('Agg')  # 必须在导入pyplot之前设置
import matplotlib.pyplot as plt
import scanpy as sc
import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings('ignore')
import os

# ======== 第三部分：分别读取和处理数据 ========
print("="*60)
print("开始分别处理Ctrl和DM组")
print("="*60)

# 定义质控函数
def process_sample(adata, sample_name, condition_name, qc_params):
    """对单个样本进行质控处理"""
    print(f"\n处理样本: {sample_name} ({condition_name})")
    
    # 1. 计算QC指标
    adata.var['mt'] = adata.var_names.str.startswith('mt-')
    sc.pp.calculate_qc_metrics(adata, qc_vars=['mt'], percent_top=None, log1p=False, inplace=True)
    
    # 2. 记录原始统计
    n_cells_before = adata.n_obs
    n_genes_before = adata.n_vars
    
    # 3. 质控过滤
    qc_pass = ((adata.obs['n_genes_by_counts'] > qc_params['nFeature_min']) & 
               (adata.obs['n_genes_by_counts'] < qc_params['nFeature_max']) & 
               (adata.obs['pct_counts_mt'] < qc_params['mt_percent_max']))
    
    adata_qc = adata[qc_pass, :].copy()
    n_cells_after = adata_qc.n_obs
    
    # 4. 打印统计
    print(f"  原始细胞数: {n_cells_before}")
    print(f"  质控后细胞数: {n_cells_after}")
    print(f"  过滤细胞数: {n_cells_before - n_cells_after}")
    print(f"  保留比例: {n_cells_after/n_cells_before:.2%}")
    
    # 5. 添加样本标签
    adata_qc.obs['sample'] = sample_name
    adata_qc.obs['condition'] = condition_name
    
    return adata, adata_qc

# ======== 分别处理Ctrl和DM ========
# 读取数据
print("\n读取数据...")
ctrl_adata_raw = sc.read_10x_mtx("ctrl_out/outs/filtered_feature_bc_matrix/", var_names='gene_symbols', cache=True)
dm_adata_raw = sc.read_10x_mtx("dm_out/outs/filtered_feature_bc_matrix/", var_names='gene_symbols', cache=True)

# 设置质控参数
qc_params = {'nFeature_min': 200, 'nFeature_max': 6000, 'mt_percent_max': 20}

# 分别处理Ctrl组
print("\n" + "="*60)
print("Ctrl组质控分析")
print("="*60)
ctrl_adata, ctrl_adata_qc = process_sample(ctrl_adata_raw, 'Ctrl', 'Control', qc_params)

# 分别处理DM组
print("\n" + "="*60)
print("DM组质控分析")
print("="*60)
dm_adata, dm_adata_qc = process_sample(dm_adata_raw, 'DM', 'Diabetes', qc_params)

# ======== 第四部分：分别可视化 ========
print("\n" + "="*60)
print("生成各组质控可视化图形")
print("="*60)

def create_qc_plots(adata, adata_qc, sample_name, save_prefix):
    """为单个样本创建QC图"""
    # 创建QC对比图
    fig, axes = plt.subplots(2, 3, figsize=(15, 10))
    
    # 质控前
    sc.pl.violin(adata, ['n_genes_by_counts'], ax=axes[0, 0], show=False)
    axes[0, 0].set_title(f'{sample_name} - Genes before QC')
    
    sc.pl.violin(adata, ['total_counts'], ax=axes[0, 1], show=False)
    axes[0, 1].set_title(f'{sample_name} - UMIs before QC')
    
    sc.pl.violin(adata, ['pct_counts_mt'], ax=axes[0, 2], show=False)
    axes[0, 2].set_title(f'{sample_name} - MT% before QC')
    
    # 质控后
    sc.pl.violin(adata_qc, ['n_genes_by_counts'], ax=axes[1, 0], show=False)
    axes[1, 0].set_title(f'{sample_name} - Genes after QC')
    
    sc.pl.violin(adata_qc, ['total_counts'], ax=axes[1, 1], show=False)
    axes[1, 1].set_title(f'{sample_name} - UMIs after QC')
    
    sc.pl.violin(adata_qc, ['pct_counts_mt'], ax=axes[1, 2], show=False)
    axes[1, 2].set_title(f'{sample_name} - MT% after QC')
    
    plt.suptitle(f'{sample_name}组质控前后对比', fontsize=16, y=1.02)
    plt.tight_layout()
    plt.savefig(f'{save_prefix}_qc_comparison.png', dpi=150, bbox_inches='tight')
    plt.close()
    print(f"✅ {sample_name}组QC对比图: {save_prefix}_qc_comparison.png")
    
    # 散点图
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    sc.pl.scatter(adata, x='total_counts', y='pct_counts_mt', ax=axes[0], show=False)
    axes[0].set_title(f'{sample_name} - UMIs vs MT% (Before QC)')
    
    sc.pl.scatter(adata_qc, x='total_counts', y='pct_counts_mt', ax=axes[1], show=False)
    axes[1].set_title(f'{sample_name} - UMIs vs MT% (After QC)')
    
    plt.suptitle(f'{sample_name}组UMIs vs MT%分布', fontsize=14, y=1.02)
    plt.tight_layout()
    plt.savefig(f'{save_prefix}_qc_scatter.png', dpi=150, bbox_inches='tight')
    plt.close()
    print(f"✅ {sample_name}组散点图: {save_prefix}_qc_scatter.png")

# 为Ctrl组创建图形
create_qc_plots(ctrl_adata, ctrl_adata_qc, 'Ctrl', 'ctrl')

# 为DM组创建图形
create_qc_plots(dm_adata, dm_adata_qc, 'DM', 'dm')

# ======== 第五部分：合并数据 ========
print("\n" + "="*60)
print("合并质控后的数据")
print("="*60)

# 合并质控后的数据
adata_qc = ctrl_adata_qc.concatenate(
    dm_adata_qc, 
    batch_key='sample',
    batch_categories=['Ctrl', 'DM']
)

print(f"合并后总细胞数: {adata_qc.n_obs}, 总基因数: {adata_qc.n_vars}")

# 查看样本分布
print("\n各样本细胞数:")
for sample in ['Ctrl', 'DM']:
    n_cells = (adata_qc.obs['sample'] == sample).sum()
    print(f"  {sample}: {n_cells} 个细胞")

# ======== 第六部分：创建组合对比图 ========
print("\n生成组合对比图...")

# 1. 各组细胞数对比
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# 质控前细胞数
before_counts = [ctrl_adata.n_obs, dm_adata.n_obs]
axes[0].bar(['Ctrl', 'DM'], before_counts, color=['skyblue', 'lightcoral'])
axes[0].set_title('质控前细胞数')
axes[0].set_ylabel('细胞数')
for i, v in enumerate(before_counts):
    axes[0].text(i, v, str(v), ha='center', va='bottom')

# 质控后细胞数
after_counts = [ctrl_adata_qc.n_obs, dm_adata_qc.n_obs]
axes[1].bar(['Ctrl', 'DM'], after_counts, color=['deepskyblue', 'tomato'])
axes[1].set_title('质控后细胞数')
axes[1].set_ylabel('细胞数')
for i, v in enumerate(after_counts):
    axes[1].text(i, v, str(v), ha='center', va='bottom')

plt.suptitle('Ctrl vs DM 质控前后细胞数对比', fontsize=14, y=1.05)
plt.tight_layout()
plt.savefig('sample_cell_counts_comparison.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ 样本细胞数对比图: sample_cell_counts_comparison.png")

# 2. 各组QC指标对比小提琴图
fig, axes = plt.subplots(1, 3, figsize=(15, 5))

# 创建临时合并数据用于可视化
adata_combined = ctrl_adata.concatenate(dm_adata, batch_key='sample', batch_categories=['Ctrl', 'DM'])
adata_qc_combined = ctrl_adata_qc.concatenate(dm_adata_qc, batch_key='sample', batch_categories=['Ctrl', 'DM'])

# 质控前的分组图
sc.pl.violin(adata_combined, 'n_genes_by_counts', groupby='sample', ax=axes[0], show=False)
axes[0].set_title('Genes per cell (Before QC)')

sc.pl.violin(adata_combined, 'total_counts', groupby='sample', ax=axes[1], show=False)
axes[1].set_title('UMIs per cell (Before QC)')

sc.pl.violin(adata_combined, 'pct_counts_mt', groupby='sample', ax=axes[2], show=False)
axes[2].set_title('MT% (Before QC)')

plt.suptitle('各组QC指标分布（质控前）', fontsize=14, y=1.05)
plt.tight_layout()
plt.savefig('qc_by_sample_before.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ 质控前分组图: qc_by_sample_before.png")

# ======== 第七部分：保存数据和报告 ========
print("\n" + "="*60)
print("保存结果")
print("="*60)

# 保存合并后的质控数据
adata_qc.write('adata_qc_filtered.h5ad')
print("✅ 合并质控数据: adata_qc_filtered.h5ad")

# 分别保存各组数据
ctrl_adata_qc.write('ctrl_adata_qc.h5ad')
dm_adata_qc.write('dm_adata_qc.h5ad')
print("✅ Ctrl组质控数据: ctrl_adata_qc.h5ad")
print("✅ DM组质控数据: dm_adata_qc.h5ad")

# 生成质控报告
with open('qc_summary_report.txt', 'w') as f:
    f.write("="*60 + "\n")
    f.write("单细胞RNA-seq质控分析报告\n")
    f.write("="*60 + "\n\n")
    
    f.write("1. Ctrl组质控结果:\n")
    f.write(f"   原始细胞数: {ctrl_adata.n_obs}\n")
    f.write(f"   质控后细胞数: {ctrl_adata_qc.n_obs}\n")
    f.write(f"   过滤细胞数: {ctrl_adata.n_obs - ctrl_adata_qc.n_obs}\n")
    f.write(f"   保留比例: {ctrl_adata_qc.n_obs/ctrl_adata.n_obs:.2%}\n\n")
    
    f.write("2. DM组质控结果:\n")
    f.write(f"   原始细胞数: {dm_adata.n_obs}\n")
    f.write(f"   质控后细胞数: {dm_adata_qc.n_obs}\n")
    f.write(f"   过滤细胞数: {dm_adata.n_obs - dm_adata_qc.n_obs}\n")
    f.write(f"   保留比例: {dm_adata_qc.n_obs/dm_adata.n_obs:.2%}\n\n")
    
    f.write("3. 总体统计:\n")
    f.write(f"   总细胞数（合并后）: {adata_qc.n_obs}\n")
    f.write(f"   Ctrl占比: {ctrl_adata_qc.n_obs/adata_qc.n_obs:.1%}\n")
    f.write(f"   DM占比: {dm_adata_qc.n_obs/adata_qc.n_obs:.1%}\n\n")
    
    f.write("4. 质控参数:\n")
    for key, value in qc_params.items():
        f.write(f"   {key}: {value}\n")

print("✅ 质控报告: qc_summary_report.txt")

print("\n" + "="*60)
print("质控分析完成！")
print("="*60)
print(f"Ctrl组: {ctrl_adata_qc.n_obs} 个细胞")
print(f"DM组: {dm_adata_qc.n_obs} 个细胞")
print(f"总计: {adata_qc.n_obs} 个细胞")

# 双细胞过滤
# 在Python中，我们使用Scrublet作为DoubletFinder的替代
sc.external.pl.scrublet_score_distribution(adata_qc, scale_hist_sim='log', figsize=(8, 4))
plt.savefig('scrublet_score_distribution.png', dpi=150, bbox_inches='tight')
plt.close()

# 在 UMAP 上查看双细胞分布
print("标准化和降维...")

# 1. 标准化
sc.pp.normalize_total(adata_qc, target_sum=1e4)
sc.pp.log1p(adata_qc)

# 2. 高变基因
sc.pp.highly_variable_genes(adata_qc, min_mean=0.0125, max_mean=3, min_disp=0.5)
adata_qc = adata_qc[:, adata_qc.var.highly_variable]

# 3. 缩放
sc.pp.scale(adata_qc, max_value=10)

# 4. PCA降维
sc.tl.pca(adata_qc, svd_solver='arpack')

# 5. 检查PCA结果
sc.pl.pca_variance_ratio(adata_qc, log=True, save='_pca_variance.png')

# ======== 邻居图和UMAP ========
print("构建邻居图...")

# 修复数据类型
adata_qc.obs['predicted_doublet'] = adata_qc.obs['predicted_doublet'].astype('category')
adata_qc.obs['sample'] = adata_qc.obs['sample'].astype('category')

# 计算邻居图（使用PCA结果）
sc.pp.neighbors(adata_qc, n_neighbors=10, n_pcs=40)

# UMAP降维
print("计算UMAP...")
sc.tl.umap(adata_qc)

# ======== 可视化 ========
print("生成可视化图形...")

# 1. 双细胞在UMAP上的分布
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# 按双细胞状态着色
sc.pl.umap(adata_qc, color=['predicted_doublet'], ax=axes[0], show=False, legend_loc='on data')
axes[0].set_title('Doublet Detection')

# 按样本着色
sc.pl.umap(adata_qc, color=['sample'], ax=axes[1], show=False, legend_loc='on data')
axes[1].set_title('Sample Grouping')

plt.suptitle('UMAP', fontsize=14, y=1.02)
plt.tight_layout()
plt.savefig('umap_doublet_sample.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ UMAP图: umap_doublet_sample.png")

# 2. 双细胞分数分布
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# 按样本分组的双细胞分数
sc.pl.violin(adata_qc, 'doublet_score', groupby='sample', ax=axes[0], show=False)
axes[0].set_title('Distribution of Doublet Scores Across Samples')

# 双细胞分数的UMAP
sc.pl.umap(adata_qc, color=['doublet_score'], ax=axes[1], show=False, cmap='viridis')
axes[1].set_title('Doublet Scores on UMAP')

plt.suptitle('Doublet Detection Analysis', fontsize=14, y=1.02)
plt.tight_layout()
plt.savefig('doublet_analysis.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ 双细胞分析图: doublet_analysis.png")

# 3. 详细的散点图
fig, axes = plt.subplots(1, 3, figsize=(15, 5))

# 双细胞分数与基因数
sc.pl.scatter(adata_qc, x='n_genes_by_counts', y='doublet_score', 
              color='predicted_doublet', ax=axes[0], show=False)
axes[0].set_title('双细胞分数 vs 基因数')

# 双细胞分数与UMI数
sc.pl.scatter(adata_qc, x='total_counts', y='doublet_score', 
              color='predicted_doublet', ax=axes[1], show=False)
axes[1].set_title('双细胞分数 vs UMI数')

# 双细胞分数与线粒体比例
sc.pl.scatter(adata_qc, x='pct_counts_mt', y='doublet_score', 
              color='predicted_doublet', ax=axes[2], show=False)
axes[2].set_title('双细胞分数 vs 线粒体%')

plt.suptitle('双细胞与QC指标关系', fontsize=14, y=1.02)
plt.tight_layout()
plt.savefig('doublet_qc_correlation.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ 双细胞-QC关系图: doublet_qc_correlation.png")

# ======== 统计报告 ========
print("\n" + "="*60)
print("双细胞检测统计报告")
print("="*60)

# 总体统计
total_cells = adata_qc.n_obs
total_doublets = (adata_qc.obs['predicted_doublet'] == True).sum()
doublet_rate = total_doublets / total_cells

print(f"总细胞数: {total_cells}")
print(f"双细胞数: {total_doublets}")
print(f"双细胞比例: {doublet_rate:.2%}")

# 按样本统计
print("\n按样本统计:")
for sample in ['Ctrl', 'DM']:
    sample_mask = adata_qc.obs['sample'] == sample
    n_cells = sample_mask.sum()
    n_doublets = (adata_qc.obs.loc[sample_mask, 'predicted_doublet'] == True).sum()
    sample_rate = n_doublets / n_cells if n_cells > 0 else 0
    
    print(f"  {sample}:")
    print(f"    细胞数: {n_cells}")
    print(f"    双细胞数: {n_doublets}")
    print(f"    比例: {sample_rate:.2%}")
    
    # 双细胞分数的统计
    scores = adata_qc.obs.loc[sample_mask, 'doublet_score']
    mean_score = scores.mean()
    median_score = scores.median()
    print(f"    平均分数: {mean_score:.3f}")
    print(f"    中位数: {median_score:.3f}")

# 保存最终数据
adata_qc.write('adata_qc_clean.h5ad')
print("\n✅ 数据已保存: adata_qc_with_umap.h5ad")

# 生成报告
with open('doublet_detection_report.txt', 'w') as f:
    f.write("="*60 + "\n")
    f.write("双细胞检测报告\n")
    f.write("="*60 + "\n\n")
    
    f.write(f"总细胞数: {total_cells}\n")
    f.write(f"双细胞数: {total_doublets}\n")
    f.write(f"双细胞比例: {doublet_rate:.2%}\n\n")
    
    f.write("按样本统计:\n")
    for sample in ['Ctrl', 'DM']:
        sample_mask = adata_qc.obs['sample'] == sample
        n_cells = sample_mask.sum()
        n_doublets = (adata_qc.obs.loc[sample_mask, 'predicted_doublet'] == True).sum()
        sample_rate = n_doublets / n_cells if n_cells > 0 else 0
        f.write(f"  {sample}: {n_cells}细胞, {n_doublets}双细胞 ({sample_rate:.2%})\n")

print("✅ 报告已保存: doublet_detection_report.txt")
print("\n双细胞检测和可视化完成！")
