# 2.3 计算自动质控阈值
calculate_sample_qc_thresholds <- function(seurat_list) {
  
  qc_thresholds <- data.frame()
  
  for (sample_name in names(seurat_list)) {
    obj <- seurat_list[[sample_name]]
    metrics <- obj@meta.data
    
    # 基因数阈值（基于MAD）
    gene_median <- median(metrics$nFeature_RNA)
    gene_mad <- mad(metrics$nFeature_RNA)
    gene_upper <- gene_median + 5 * gene_mad
    gene_lower <- max(200, gene_median - 5 * gene_mad)
    
    # UMI数阈值
    umi_median <- median(log10(metrics$nCount_RNA + 1))
    umi_mad <- mad(log10(metrics$nCount_RNA + 1))
    umi_upper <- 10^(umi_median + 5 * umi_mad)
    umi_lower <- 10^(max(0, umi_median - 5 * umi_mad))
    
    # 线粒体百分比阈值
    mt_upper <- quantile(metrics$percent.mt, 0.99, na.rm = TRUE)
    
    thresholds <- data.frame(
      Sample = sample_name,
      Group = unique(obj$group),
      nFeature_min = gene_lower,
      nFeature_max = gene_upper,
      nCount_min = umi_lower,
      nCount_max = umi_upper,
      percent_mt_max = min(20, mt_upper)  # 不超过20%
    )
    
    qc_thresholds <- rbind(qc_thresholds, thresholds)
  }
  
  return(qc_thresholds)
}

qc_thresholds <- calculate_sample_qc_thresholds(seurat_list)
write.csv(qc_thresholds, "tables/QC_thresholds_by_sample.csv", row.names = FALSE)

# 2.4 应用质控过滤

for (sample_name in names(seurat_list)) {
  cat(paste("  过滤样本:", sample_name, "\n"))
  obj <- seurat_list[[sample_name]]
  thresholds <- qc_thresholds[qc_thresholds$Sample == sample_name, ]
  
  # 过滤条件
  cells_keep <- (
    obj$nFeature_RNA >= thresholds$nFeature_min &
    obj$nFeature_RNA <= thresholds$nFeature_max &
    obj$nCount_RNA >= thresholds$nCount_min &
    obj$nCount_RNA <= thresholds$nCount_max &
    obj$percent.mt <= thresholds$percent_mt_max
  )
  
  # 应用过滤
  obj <- subset(obj, cells = colnames(obj)[cells_keep])
  seurat_list[[sample_name]] <- obj
  
  cat(paste("    保留细胞数:", ncol(obj), 
            "(", round(mean(cells_keep) * 100, 1), "%)\n"))
}

