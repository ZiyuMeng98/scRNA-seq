# 5.1 定义心脏组织的细胞类型marker基因
cardiac_markers <- list(
  Cardiomyocyte = c("Tnnt2", "Myh7", "Myh6", "Nppa", "Nppb", "Ttn", "Ryr2", "Actc1", "Myl2"),
  Fibroblast = c("Col1a1", "Col3a1", "Dcn", "Fbln1", "Pdgfra", "Lum", "Postn", "Tcf21"),
  Endothelial = c("Pecam1", "Vwf", "Cdh5", "Cldn5", "Sele", "Cd34", "Emcn", "Kdr"),
  Macrophage = c("Cd14", "Cd68", "Itgax", "H2-Aa", "Csf1r", "Cd163", "Mrc1", "Adgre1"),
  T_Cell = c("Cd3d", "Cd3e", "Cd4", "Cd8a", "Il7r", "Trac", "Trbc2", "Cd3g"),
  B_Cell = c("Ms4a1", "Cd79a", "Cd19", "Cd79b", "Bank1", "Cd20"),
  NK_Cell = c("Nkg7", "Gnly", "Klrd1", "Klrf1", "Ncr1"),
  Monocyte = c("Cd14", "Fcgr3", "S100a8", "S100a9", "Vcan"),
  Dendritic_Cell = c("Cd1c", "Clec9a", "Xcr1", "Batf3", "Irf8"),
  Smooth_Muscle = c("Acta2", "Myh11", "Tagln", "Cnn1", "Mylk"),
  Pericyte = c("Rgs5", "Pdgfrb", "Cspg4", "Kcnj8", "Abcc9"),
  Adipocyte = c("Adipoq", "Lep", "Fabp4", "Plin1", "Cidea"),
  Neuron = c("Nefl", "S100b", "Plp1", "Rbfox3", "Syp"),
  Erythrocyte = c("Hba-a1", "Hba-a2", "Hbb-bt", "Hbb-bs", "Alas2"),
  Platelet = c("Ppbp", "Pf4", "Itga2b", "Gp1ba", "Clu")
)

# 5.2 计算细胞类型得分
cat("计算细胞类型得分...\n")

# 为每个细胞类型计算模块得分
for (cell_type in names(cardiac_markers)) {
  markers <- cardiac_markers[[cell_type]]
  
  # 只保留在数据中存在的基因
  markers_present <- markers[markers %in% rownames(merged_obj)]
  
  if (length(markers_present) >= 3) {
    cat(sprintf("  为 %s 计算得分 (使用 %d/%d 个基因)\n", 
                cell_type, length(markers_present), length(markers)))
    
    merged_obj <- AddModuleScore(
      merged_obj,
      features = list(markers_present),
      name = cell_type,
      ctrl = 100,
      assay = DefaultAssay(merged_obj)  # 使用当前默认assay
    )
  } else {
    cat(sprintf("  跳过 %s: 在数据中只找到 %d 个基因 (需要至少3个)\n", 
                cell_type, length(markers_present)))
  }
}

# 5.3 自动注释细胞类型
cat("\n自动注释细胞类型...\n")

# 创建得分矩阵
score_columns <- paste0(names(cardiac_markers), "1")
score_columns <- score_columns[score_columns %in% colnames(merged_obj@meta.data)]

if (length(score_columns) > 0) {
  score_matrix <- merged_obj@meta.data[, score_columns, drop = FALSE]
  colnames(score_matrix) <- gsub("1$", "", colnames(score_matrix))
  
  # 为每个细胞分配得分最高的细胞类型
  cell_type_assignments <- apply(score_matrix, 1, function(scores) {
    if (max(scores) > 0.5) {  # 阈值
      names(which.max(scores))
    } else {
      "Unknown"
    }
  })
  
  merged_obj$predicted_celltype <- cell_type_assignments
  
  # 统计细胞类型分布
  celltype_counts <- table(merged_obj$predicted_celltype)
  cat("\n细胞类型分布:\n")
  print(celltype_counts)
} else {
  cat("警告：未找到任何细胞类型得分列\n")
  merged_obj$predicted_celltype <- rep("Unknown", ncol(merged_obj))
}

# 5.4 使用SingleR进行验证（可选，但推荐）
