# 加载单个样本的函数
load_single_sample <- function(sample_id, data_path, group) {
  cat(paste("  加载样本:", sample_id, "\n"))  
  # 使用Read10X读取10X数据
  data <- Read10X(data.dir = data_path)
  seurat_obj <- CreateSeuratObject(counts = data, project = sample_id, min.cells = 3, min.features = 200)  
  # 添加样本信息
  seurat_obj$sample_id <- sample_id
  seurat_obj$group <- group
  seurat_obj$batch <- sample_info$batch[sample_info$sample_id == sample_id]  
  return(seurat_obj)
}

# 加载所有样本
cat("加载所有8个样本...\n")
seurat_list <- list()

for (i in 1:nrow(sample_info)) {
  sample_row <- sample_info[i, ]
  seurat_obj <- load_single_sample(sample_id = sample_row$sample_id, data_path = sample_row$data_path, group = sample_row$group)
  seurat_list[[sample_row$sample_id]] <- seurat_obj
}

