			   ref = my_ref, 
			   labels = my_ref$label.main,
			   # 可以加入method = "cluster"
			   # 加入method时要加入clusters = clusters，作为对类群注释，速度更快，不加入时对每个细胞注释，运行时间长		  	                   assay.type.test = "logcounts",  # 指定测试数据使用 logcounts
                           assay.type.ref = "logcounts")

# 将结果添加到原始对象
merged_obj$SingleR_labels <- singler_results$labels
merged_obj$SingleR_scores <- singler_results$scores

