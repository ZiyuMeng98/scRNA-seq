# 6. 差异表达分析
# ============================================================================
cat("\n=== 6. 差异表达分析 ===\n")


# 6.1 设置差异分析的ident
Idents(merged_obj) <- "predicted_celltype"

# 6.2 查找细胞类型特异的marker基因
cat("查找细胞类型特异的marker基因...\n")

merged_obj <- PrepSCTFindMarkers(merged_obj)
celltype_markers <- FindAllMarkers(
  merged_obj,
  only.pos = TRUE,
  min.pct = 0.25,
  logfc.threshold = 0.25,
  test.use = "wilcox"
)

# 保存结果
write.csv(celltype_markers, "tables/celltype_specific_markers.csv", row.names = FALSE)

# 6.3 组间差异分析（DM vs Ctrl）
cat("进行组间差异分析（DM vs Ctrl）...\n")

# 为每个细胞类型进行DM vs Ctrl的差异分析
de_results_by_celltype <- list()

unique_celltypes <- unique(merged_obj$predicted_celltype)
for (celltype in unique_celltypes) {
  cat(paste("  分析细胞类型:", celltype, "\n"))

  # 提取该细胞类型的子集
  cells_subset <- WhichCells(merged_obj, expression = predicted_celltype == celltype)
  subset_obj <- subset(merged_obj, cells = cells_subset)

  if (ncol(subset_obj) < 10) {
    cat(paste("    细胞数太少(", ncol(subset_obj), ")，跳过\n"))
    next
  }

  # 设置ident为group
  Idents(subset_obj) <- "group"

  # 强制重新计算SCT以避免PrepSCTFindMarkers错误
  # 先提取原始counts
  counts <- GetAssayData(subset_obj, assay = "RNA", layer = "counts")  # 修改这里

  # 重新创建Seurat对象
  subset_obj <- CreateSeuratObject(counts = counts, meta.data = subset_obj@meta.data)
  subset_obj$group <- subset_obj@meta.data$group

  # 重新进行SCT变换
  subset_obj <- SCTransform(subset_obj, vars.to.regress = c("nCount_RNA", "percent.mt"), verbose = FALSE)

  # 设置ident
  Idents(subset_obj) <- "group"

  # 查找差异基因
  de_genes <- FindMarkers(
    subset_obj,
    assay = "SCT",  # 明确指定使用SCT assay
    ident.1 = "DM",
    ident.2 = "Ctrl",
    min.pct = 0.1,
    logfc.threshold = 0.25,
    test.use = "wilcox"
  )

  # 添加基因名和细胞类型
  de_genes$gene <- rownames(de_genes)
  de_genes$celltype <- celltype
  de_genes$direction <- ifelse(de_genes$avg_log2FC > 0, "Up_in_DM", "Down_in_DM")

  de_results_by_celltype[[celltype]] <- de_genes

  # 保存每个细胞类型的差异基因
  write.csv(de_genes, paste0("tables/DE_genes_", gsub("/", "_", celltype), "_DM_vs_Ctrl.csv"),row.names = FALSE)
}
# 报错如下时无需处理，单细胞数据中有很多基因在很多细胞中表达为零
#   cannot compute exact p-value with ties

# 6.4 合并所有差异分析结果
all_de_genes <- do.call(rbind, de_results_by_celltype)
write.csv(all_de_genes, "tables/all_DE_genes_by_celltype.csv", row.names = FALSE)

# 6.5 绘制差异基因热图
cat("绘制差异基因热图...\n")

# 选择每个细胞类型的top差异基因
# 提取top差异基因
top_de_genes <- all_de_genes %>%
  group_by(celltype) %>%
  filter(p_val_adj < 0.05) %>%
  arrange(desc(abs(avg_log2FC))) %>%
  slice_head(n = 5) %>%
  ungroup()

if (nrow(expr_matrix) > 0) {
  # 对数据进行缩放
  expr_scaled <- t(scale(t(expr_matrix)))
  expr_scaled[is.na(expr_scaled)] <- 0
  expr_scaled[is.infinite(expr_scaled)] <- 0

  # 确保使用 pheatmap 包，而不是 ComplexHeatmap 的版本
  if ("package:ComplexHeatmap" %in% search()) {
    detach("package:ComplexHeatmap", unload = TRUE)
  }
  library(pheatmap)

  # 直接保存为文件（不使用 ggsave）
  pheatmap(expr_scaled,
           color = colorRampPalette(c("blue", "white", "red"))(50),
           main = "Top DE Genes by Cell Type and Group",
           cluster_rows = TRUE,
           cluster_cols = FALSE,   # 不聚类列
           show_rownames = TRUE,
           fontsize_row = 8,
           angle_col = "45",
           filename = "figures/DE_genes_heatmap.png",   # 直接保存
           width = 12,            # 单位：英寸
           height = 10,
           dpi = 300)

  cat("热图已保存到: figures/DE_genes_heatmap.png\n")
}

# 7. 通路富集分析
# ============================================================================
cat("\n=== 7. 通路富集分析 ===\n")

cat("进行通路富集分析...\n")
go_results_by_celltype <- list()

for (celltype in unique_celltypes) {
  if (!celltype %in% names(de_results_by_celltype)) {
    cat("跳过", celltype, "：不在de_results_by_celltype中\n")
    next
  }
  
  de_data <- de_results_by_celltype[[celltype]]
  
  # 筛选显著上调的基因
  up_genes <- de_data %>%
    filter(p_val_adj < 0.05 & avg_log2FC > 0.5) %>%
    pull(gene)
  
  cat("细胞类型", celltype, "：找到", length(up_genes), "个上调基因\n")
  
  if (length(up_genes) < 5) {
    cat("  上调基因不足5个，跳过GO分析\n")
    next
  }
  
  # 基因ID转换（Symbol -> ENTREZID）
  suppressMessages({
    id_conversion <- tryCatch(
      bitr(up_genes, 
           fromType = "SYMBOL", 
           toType = "ENTREZID", 
           OrgDb = org.Mm.eg.db),
      error = function(e) {
        cat("  基因ID转换失败:", e$message, "\n")
        return(NULL)
      }
    )
  })
  
  if (is.null(id_conversion) || nrow(id_conversion) == 0) {
    cat("  无有效的ENTREZID，跳过\n")
    next
  }
  
  up_genes_entrez <- id_conversion$ENTREZID
  
  # GO富集分析（BP）
  go_up <- tryCatch(
    enrichGO(gene = up_genes_entrez,
             OrgDb = org.Mm.eg.db,
             ont = "BP",
             pAdjustMethod = "BH",
             pvalueCutoff = 0.05,
             qvalueCutoff = 0.05,
             readable = TRUE),
    error = function(e) {
      cat("  富集分析出错:", e$message, "\n")
      return(NULL)
    }
  )
  
  if (is.null(go_up) || nrow(go_up) == 0) {
    cat("  未得到显著的GO term\n")
    next
  }
  
  # 保存结果对象
  go_results_by_celltype[[paste0(celltype, "_up")]] <- go_up
  
  # 绘制气泡图（top 10）
  p <- dotplot(go_up, showCategory = 10) +
    ggtitle(paste("GO Enrichment -", celltype, "(Up in DM)")) +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))
  
  # 保存图片（文件名中避免特殊字符）
  safe_name <- gsub("/", "_", celltype)
  ggsave(filename = paste0("figures/GO_", safe_name, "_up.png"),
         plot = p, width = 10, height = 8, dpi = 300)
  
  cat("  已保存", celltype, "的GO结果，显著term数:", nrow(go_up), "\n")
}
# 上述报warning massages正常，In bitr(up_genes, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Mm.eg.db) 下面较小（这项中是小于4%）影响不大

cat("\n=== 开始整体差异表达分析 (Ctrl vs DM) ===\n")

# 1. 设置默认 assay 和身份类别
DefaultAssay(merged_obj) <- "RNA"
Idents(merged_obj) <- merged_obj$group   # 假设 group 列包含 "Ctrl" 和 "DM"

# 2. 整体差异表达分析（将所有细胞视为一个群体）
# 注意：这种方法会受到细胞组成偏移的影响，仅供整体趋势参考
de_all <- FindMarkers(merged_obj,
                      ident.1 = "DM",
                      ident.2 = "Ctrl",
                      logfc.threshold = 0,
                      min.pct = 0.1,
                      test.use = "wilcox")   # 或 "MAST" 但较慢

# 添加基因列
de_all$gene <- rownames(de_all)

# 筛选显著差异基因
sig_all <- de_all %>%
  filter(p_val_adj < 0.05, abs(avg_log2FC) > 0.5)

# 上调基因（DM 中高表达）
up_all <- sig_all %>%
  filter(avg_log2FC > 0.5) %>%
  pull(gene)

# 下调基因（Ctrl 中高表达 / DM 中低表达）
down_all <- sig_all %>%
  filter(avg_log2FC < -0.5) %>%
  pull(gene)

cat(sprintf("整体差异基因: 上调 %d 个, 下调 %d 个\n", length(up_all), length(down_all)))

# 3. 基因ID转换函数（带错误处理和映射率提示）
convert_genes <- function(genes, name) {
  if (length(genes) < 5) {
    cat(sprintf("%s 基因数量不足5个，跳过转换\n", name))
    return(NULL)
  }
  suppressWarnings({
    conv <- bitr(genes, 
                 fromType = "SYMBOL", 
                 toType = "ENTREZID", 
                 OrgDb = org.Mm.eg.db)
  })
  if (is.null(conv) || nrow(conv) == 0) {
    cat(sprintf("%s 基因ID转换失败或空结果\n", name))
    return(NULL)
  }
  cat(sprintf("%s 基因转换成功: %d/%d (%.1f%%)\n", 
              name, nrow(conv), length(genes), nrow(conv)/length(genes)*100))
  return(conv$ENTREZID)
}

up_entrez <- convert_genes(up_all, "整体上调")
down_entrez <- convert_genes(down_all, "整体下调")

# 4. 执行 GO 富集分析（BP）
if (!is.null(up_entrez) && length(up_entrez) >= 5) {
  go_up_all <- enrichGO(gene = up_entrez,
                        OrgDb = org.Mm.eg.db,
                        ont = "BP",
                        pAdjustMethod = "BH",
                        pvalueCutoff = 0.05,
                        qvalueCutoff = 0.05,
                        readable = TRUE)
} else {
  go_up_all <- NULL
}

if (!is.null(down_entrez) && length(down_entrez) >= 5) {
  go_down_all <- enrichGO(gene = down_entrez,
                          OrgDb = org.Mm.eg.db,
                          ont = "BP",
                          pAdjustMethod = "BH",
                          pvalueCutoff = 0.05,
                          qvalueCutoff = 0.05,
                          readable = TRUE)
} else {
  go_down_all <- NULL
}

# 5. 保存结果
dir.create("figures", showWarnings = FALSE)
dir.create("objects", showWarnings = FALSE)

# 保存 RDS
saveRDS(list(up = go_up_all, down = go_down_all), file = "objects/GO_overall_results.rds")

# 保存表格
if (!is.null(go_up_all) && nrow(go_up_all) > 0) {
  write.csv(as.data.frame(go_up_all), "tables/GO_overall_up.csv", row.names = FALSE)
}
if (!is.null(go_down_all) && nrow(go_down_all) > 0) {
  write.csv(as.data.frame(go_down_all), "tables/GO_overall_down.csv", row.names = FALSE)
}

# 6. 可视化
# 上调基因的气泡图
if (!is.null(go_up_all) && nrow(go_up_all) > 0) {
  suppressWarnings({
    p_up <- dotplot(go_up_all, showCategory = 15) +
      ggtitle("GO Enrichment (DM vs Ctrl) - Up-regulated genes in DM") +
      theme(axis.text.x = element_text(angle = 45, hjust = 1))
    ggsave("figures/GO_overall_up_dotplot.png", p_up, width = 12, height = 10, dpi = 300)
    
    p_up_bar <- barplot(go_up_all, showCategory = 15) +
      ggtitle("GO Enrichment (DM vs Ctrl) - Up-regulated genes in DM")
    ggsave("figures/GO_overall_up_barplot.png", p_up_bar, width = 10, height = 8, dpi = 300)
  })
}

if (!is.null(go_down_all) && nrow(go_down_all) > 0) {
  suppressWarnings({
    p_down <- dotplot(go_down_all, showCategory = 15) +
      ggtitle("GO Enrichment (DM vs Ctrl) - Down-regulated genes in DM") +
      theme(axis.text.x = element_text(angle = 45, hjust = 1))
    ggsave("figures/GO_overall_down_dotplot.png", p_down, width = 12, height = 10, dpi = 300)
    
    p_down_bar <- barplot(go_down_all, showCategory = 15) +
      ggtitle("GO Enrichment (DM vs Ctrl) - Down-regulated genes in DM")
    ggsave("figures/GO_overall_down_barplot.png", p_down_bar, width = 10, height = 8, dpi = 300)
  })
}

if (!is.null(go_up_all) && !is.null(go_down_all)) {
  suppressWarnings({
    up_top <- go_up_all@result[1:min(10, nrow(go_up_all)), ]
    down_top <- go_down_all@result[1:min(10, nrow(go_down_all)), ]
    up_top$Regulation <- "Up in DM"
    down_top$Regulation <- "Down in DM"
    combined <- rbind(up_top, down_top)
    library(ggplot2)
    combined$Description <- factor(combined$Description, 
                                   levels = c(rev(up_top$Description), rev(down_top$Description)))
    p_comb <- ggplot(combined, aes(x = Description, y = -log10(p.adjust), fill = Regulation)) +
      geom_col(position = position_dodge(0.9), width = 0.7) +
      coord_flip() +
      labs(title = "GO Enrichment (DM vs Ctrl) - Top terms",
           x = "", y = "-log10(adjusted p-value)") +
      theme_bw() +
      theme(axis.text.y = element_text(size = 10))
    ggsave("figures/GO_overall_combined_barplot.png", p_comb, width = 12, height = 10, dpi = 300)
  })
}

# 保存全部GO结果到RDS
saveRDS(go_results_by_celltype, "objects/GO_results_by_celltype.rds")
cat("所有GO分析完成，结果已保存至 objects/GO_results_by_celltype.rds\n")

