# 3.1 对每个样本进行SCTransform
for (sample_name in names(seurat_list)) {
  cat(paste("  SCTransform处理样本:", sample_name, "\n"))
  obj <- seurat_list[[sample_name]]
  
  # 确保有percent.mt
  if (is.null(obj$percent.mt)) {
    obj[["percent.mt"]] <- PercentageFeatureSet(obj, pattern = "^MT-")
  }
  
  # 运行SCTransform
  obj <- SCTransform(obj, vst.flavor = "v1", vars.to.regress = c("percent.mt", "nCount_RNA"), verbose = FALSE)
  seurat_list[[sample_name]] = obj
}

