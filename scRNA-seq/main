p_after <- DimPlot(merged_obj, 
                  reduction = "harmony",  # 使用harmony
                  group.by = "sample_id",
                  shuffle = TRUE,
                  pt.size = 0.5) +
  scale_color_brewer(palette = "Set3") +
  ggtitle("After Harmony: Harmony colored by Sample") +
  theme_minimal()

batch_correction_plot <- (p_before | p_after) + plot_layout(ncol = 2)

ggsave("figures/batch_correction_comparison.png", batch_correction_plot,width = 12, height = 5, dpi = 300, bg = "white")

# 按组着色
p_group <- DimPlot(merged_obj, 
                  reduction = "umap_harmony", 
                  group.by = "group",
                  shuffle = TRUE,
                  pt.size = 0.5) +
  scale_color_brewer(palette = "Set1") +
  ggtitle("UMAP: Colored by Group") +
  theme_minimal()

