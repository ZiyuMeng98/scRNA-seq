# 定义质控函数
def process_sample(adata, sample_name, condition_name, qc_params):
    """对单个样本进行质控处理"""
    print(f"\n处理样本: {sample_name} ({condition_name})")
    
    # 1. 计算QC指标
    adata.var['mt'] = adata.var_names.str.startswith('mt-')
    sc.pp.calculate_qc_metrics(adata, qc_vars=['mt'], percent_top=None, log1p=False, inplace=True)
    
    # 2. 记录原始统计
    n_cells_before = adata.n_obs
    n_genes_before = adata.n_vars
    
    # 3. 质控过滤
    qc_pass = ((adata.obs['n_genes_by_counts'] > qc_params['nFeature_min']) & 
               (adata.obs['n_genes_by_counts'] < qc_params['nFeature_max']) & 
               (adata.obs['pct_counts_mt'] < qc_params['mt_percent_max']))
    
    adata_qc = adata[qc_pass, :].copy()
    n_cells_after = adata_qc.n_obs
    
    # 4. 打印统计
    print(f"  原始细胞数: {n_cells_before}")
    print(f"  质控后细胞数: {n_cells_after}")
    print(f"  过滤细胞数: {n_cells_before - n_cells_after}")
    print(f"  保留比例: {n_cells_after/n_cells_before:.2%}")
    
    # 5. 添加样本标签
    adata_qc.obs['sample'] = sample_name
    adata_qc.obs['condition'] = condition_name
    
    return adata, adata_qc

