adata = sc.read('adata_qc_clean.h5ad')
print(f"数据形状: {adata.shape}")
print(f"总细胞数: {adata.n_obs}")
print(f"总基因数: {adata.n_vars}")

# 检查NaN值
print("\n检查数据中的NaN值...")
if sparse.issparse(adata.X):
    # 稀疏矩阵检查
    nnz = adata.X.nnz
    total_elements = adata.n_obs * adata.n_vars
    sparsity = 1 - (nnz / total_elements)
    print(f"稀疏矩阵: 非零元素 = {nnz}, 稀疏性 = {sparsity:.2%}")
    
    # 检查是否有显式的NaN
    if hasattr(adata.X, 'data'):
        nan_count = np.isnan(adata.X.data).sum()
        print(f"稀疏矩阵中的NaN值: {nan_count}")
else:
    # 稠密矩阵检查
    nan_count = np.isnan(adata.X).sum()
    print(f"稠密矩阵中的NaN值: {nan_count}")

# 检查基因的平均表达
print("\n计算基因平均表达...")
if sparse.issparse(adata.X):
    # 对稀疏矩阵高效计算
    gene_means = np.array(adata.X.mean(axis=0)).flatten()
else:
    gene_means = adata.X.mean(axis=0)

print(f"基因平均表达范围: [{gene_means.min():.3e}, {gene_means.max():.3e}]")
print(f"平均表达为0的基因数: {(gene_means == 0).sum()}")

# 检查是否有无限值
if not sparse.issparse(adata.X):
    inf_count = np.isinf(adata.X).sum()
    print(f"无限值数量: {inf_count}")

# ======== 步骤2：数据归一化 ========
print("\n" + "="*60)
print("步骤2: 数据归一化")
print("="*60)

# 检查当前数据
print("检查当前数据...")
if sparse.issparse(adata.X):
    current_sum = adata.X.sum()
    if hasattr(current_sum, 'toarray'):
        current_sum = current_sum.toarray()[0,0]
    print(f"当前总表达量: {current_sum:.1f}")
else:
    print(f"当前总表达量: {adata.X.sum():.1f}")

# 2.1 总计数归一化
print("\n2.1 总计数归一化到10,000")
try:
    sc.pp.normalize_total(adata, target_sum=1e4)
    print(f"归一化后平均总计数: {adata.X.sum(axis=1).mean():.1f}")
except Exception as e:
    print(f"归一化出错: {e}")
    print("尝试手动归一化...")
    # 手动归一化
    from sklearn.preprocessing import normalize
    if sparse.issparse(adata.X):
        adata.X = normalize(adata.X, norm='l1', axis=1) * 1e4
    else:
        adata.X = normalize(adata.X, norm='l1', axis=1) * 1e4
    print(f"手动归一化完成，平均总计数: {adata.X.sum(axis=1).mean():.1f}")

# 2.2 对数转换
print("\n2.2 对数转换 (log1p)")
try:
    sc.pp.log1p(adata)
    print("✅ 对数转换完成")
except Exception as e:
    print(f"对数转换出错: {e}")
    print("确保数据非负...")
    # 确保数据非负
    if sparse.issparse(adata.X):
        adata.X.data = np.maximum(adata.X.data, 0)
    else:
        adata.X = np.maximum(adata.X, 0)
    sc.pp.log1p(adata)
    print("对数转换完成")

# 再次检查NaN
if not sparse.issparse(adata.X):
    nan_after = np.isnan(adata.X).sum()
    print(f"归一化后NaN值: {nan_after}")
    if nan_after > 0:
        print("⚠️ 仍有NaN值，替换为0")
        adata.X = np.nan_to_num(adata.X, nan=0.0)

# 保存归一化后的数据
adata.write('adata_normalized.h5ad')
print("✅ 保存归一化数据: adata_normalized.h5ad")

# ======== 步骤3：高变基因选择（修复版） ========
print("\n" + "="*60)
print("步骤3: 高变基因选择（修复版）")
print("="*60)

# 3.1 手动计算高变基因
print("手动计算基因统计...")

# 计算每个基因的均值和方差
if sparse.issparse(adata.X):
    # 稀疏矩阵的高效计算
    gene_means = np.array(adata.X.mean(axis=0)).flatten()
    # 计算方差
    gene_vars = np.array((adata.X.power(2)).mean(axis=0)).flatten() - gene_means**2
else:
    gene_means = adata.X.mean(axis=0)
    gene_vars = adata.X.var(axis=0)

# 避免除零错误
epsilon = 1e-10
gene_vars = np.maximum(gene_vars, epsilon)

# 计算离散度
gene_dispersions = gene_vars / (gene_means + epsilon)

# 存储到adata.var
adata.var['means'] = gene_means
adata.var['variances'] = gene_vars
adata.var['dispersions'] = gene_dispersions

print(f"基因统计:")
print(f"  平均表达范围: [{gene_means.min():.3e}, {gene_means.max():.3e}]")
print(f"  方差范围: [{gene_vars.min():.3e}, {gene_vars.max():.3e}]")
print(f"  离散度范围: [{gene_dispersions.min():.3e}, {gene_dispersions.max():.3e}]")

# 3.2 手动选择高变基因
print("\n手动选择高变基因...")

# 过滤低表达基因
min_mean_threshold = 0.01
mean_filter = gene_means >= min_mean_threshold
print(f"平均表达 >= {min_mean_threshold} 的基因数: {mean_filter.sum()}")

if mean_filter.sum() < 100:
    print("⚠️ 高表达基因太少，降低阈值...")
    min_mean_threshold = 0.001
    mean_filter = gene_means >= min_mean_threshold
    print(f"新阈值下基因数: {mean_filter.sum()}")

# 归一化离散度
from scipy import stats
valid_dispersions = gene_dispersions[mean_filter]
if len(valid_dispersions) > 0:
    # 归一化到均值为0，标准差为1
    disp_norm = stats.zscore(np.log1p(valid_dispersions))
    disp_norm = np.nan_to_num(disp_norm, nan=0.0)
    
    # 选择top基因
    n_top_genes = min(2000, mean_filter.sum())
    if n_top_genes > 0:
        # 按归一化离散度排序
        top_indices = np.argsort(disp_norm)[-n_top_genes:]
        # 获取原始索引
        all_indices = np.where(mean_filter)[0]
        top_gene_indices = all_indices[top_indices]
        
        # 标记高变基因
        adata.var['highly_variable'] = False
        adata.var.iloc[top_gene_indices, adata.var.columns.get_loc('highly_variable')] = True
        adata.var['dispersions_norm'] = 0.0
        adata.var.iloc[all_indices, adata.var.columns.get_loc('dispersions_norm')] = disp_norm
        
        n_hv_genes = adata.var['highly_variable'].sum()
        print(f"✅ 选择高变基因数: {n_hv_genes}")
    else:
        print("⚠️ 没有符合条件的基因，使用所有基因")
        adata.var['highly_variable'] = True
        n_hv_genes = adata.n_vars
else:
    print("⚠️ 没有有效的离散度值，使用所有基因")
    adata.var['highly_variable'] = True
    n_hv_genes = adata.n_vars

print(f"高变基因比例: {n_hv_genes/adata.n_vars:.2%}")

# 3.3 可视化
print("\n生成高变基因可视化...")
fig, axes = plt.subplots(1, 2, figsize=(12, 5))

# 均值-离散度图
if 'dispersions_norm' in adata.var.columns:
    # 所有基因
    axes[0].scatter(adata.var['means'], adata.var['dispersions_norm'], 
                   alpha=0.1, s=5, c='gray', label='all Genes')
    
    # 高变基因
    hv_mask = adata.var['highly_variable']
    axes[0].scatter(adata.var.loc[hv_mask, 'means'], 
                   adata.var.loc[hv_mask, 'dispersions_norm'],
                   alpha=0.7, s=10, c='red', label='HVGs')
    
    axes[0].set_xlabel('平均表达 (log)')
    axes[0].set_ylabel('归一化离散度')
    axes[0].set_title('高变基因选择')
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)
else:
    axes[0].text(0.5, 0.5, '无离散度数据', ha='center', va='center')
    axes[0].set_title('HVGs')

# 基因分类统计
categories = ['HVGs', 'Not HVGs']
values = [n_hv_genes, adata.n_vars - n_hv_genes]
colors = ['lightcoral', 'lightblue']

bars = axes[1].bar(categories, values, color=colors)
axes[1].set_ylabel('Number of genes')
axes[1].set_title('Gene Classification Statistics')

for bar, value in zip(bars, values):
    height = bar.get_height()
    axes[1].text(bar.get_x() + bar.get_width()/2., height + 5,
                f'{value}', ha='center', va='bottom')

plt.tight_layout()
plt.savefig('highly_variable_genes_fixed.png', dpi=150, bbox_inches='tight')
plt.close()
print("✅ 高变基因选择图: highly_variable_genes_fixed.png")

