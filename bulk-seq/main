    dir=$(basename "$i")
    echo "fasterq-dump $srr_dir/$dir.sra --split-files --threads 2"
done > command.sra_to_fastq.list
ParaFly -c command.sra_to_fastq.list -CPU 8

FASTQ_DIR="/home/stu_wangyanan/working/scrna-seq/02.bulk_seq/00.raw_data"
QC_DIR="/home/stu_wangyanan/working/scrna-seq/02.bulk_seq/01.qc"
fastqc -o $QC_DIR -t 4 $FASTQ_DIR/*.fastq.gz
cd /home/stu_wangyanan/working/scrna-seq/02.bulk_seq/01.qc
multiqc .

# 构建STAR索引进行比对 
# 确定读长参数 --sjdbOverhang，返回值减1为--sjdbOverhang参数值，这里返回了142，所以索引构建和后续比对使用141
zcat 00.raw_data/SRR21943973_1.fastq.gz | head -4 | awk 'NR==2{print length($0)}'
# 构建索引
 STAR --runMode genomeGenerate \
      --genomeDir /home/stu_wangyanan/working/scrna-seq/00.incipient_data/ref_genomic/refdata-gex-mm10-2020-A/STAR \
      --genomeFastaFiles /home/stu_wangyanan/working/scrna-seq/00.incipient_data/ref_genomic/refdata-gex-mm10-2020-A/fasta/genome.fa \
      --sjdbGTFfile /home/stu_wangyanan/working/scrna-seq/00.incipient_data/ref_genomic/refdata-gex-mm10-2020-A/genes/genes.gtf \
      --sjdbOverhang 141 \
      --runThreadN 8
# 比对
while read sample; do
    STAR --genomeDir /home/stu_wangyanan/working/scrna-seq/00.incipient_data/ref_genomic/refdata-gex-mm10-2020-A/STAR \
         --readFilesIn 02.trimmed/${sample}_1.fastq.gz 02.trimmed/${sample}_2.fastq.gz \
         --readFilesCommand zcat \
         --outFileNamePrefix 03.align/${sample}_ \
         --outSAMtype BAM SortedByCoordinate \
         --quantMode GeneCounts \
         --sjdbOverhang 141 \
         --runThreadN 8; 
done < samples.txt

# 查看结果读数，检查比对质量
# 小鼠 bulk RNA-seq 的正常范围：唯一比对率 85%～90% 左右，大幅度低于80%时需要检查接头是否去除干净，索引是否正确，以及--sjdbOverhang 是否设置正确
# 只有个别样本异常，可能是该样本降解或污染
grep "Uniquely mapped reads %" *Log.final.out

# ==========
# 获取基因表达矩阵（R）
# ==========
R
align_dir <- getwd()
# 列出所有 ReadsPerGene.out.tab 文件
tab_files <- list.files(path = align_dir, pattern = "ReadsPerGene.out.tab$", full.names = TRUE)
# 提取样本名
sample_names <- gsub("_ReadsPerGene.out.tab$", "", basename(tab_files))
cat("找到", length(tab_files), "个样本:", sample_names, "\n")
# 读取第一个文件，固定基因顺序
first <- read.table(tab_files[1], skip = 4,
                    col.names = c("gene", "unstranded", "strand1", "strand2"))
gene_ids <- first$gene
# 初始化计数矩阵
counts <- matrix(0, nrow = length(gene_ids), ncol = length(tab_files))
colnames(counts) <- sample_names
rownames(counts) <- gene_ids
# 逐文件读取并安全填充
for (i in seq_along(tab_files)) {
    tmp <- read.table(tab_files[i], skip = 4,
                      col.names = c("gene", "unstranded", "strand1", "strand2"))
    # 确保基因顺序一致
    if (!identical(tmp$gene, gene_ids)) {
        idx <- match(gene_ids, tmp$gene)
        if (anyNA(idx)) warning("文件 ", basename(tab_files[i]), " 缺少部分基因")
        counts[, i] <- tmp$unstranded[idx]
    } else {
        counts[, i] <- tmp$unstranded
    }
}
# 看一眼结果
head(counts)
dim(counts)
# 保存到项目根目录
write.csv(counts, file.path(align_dir, "counts_matrix.csv"))
cat("计数矩阵已保存至:", file.path(align_dir, "counts_matrix.csv"), "\n")

# 差异表达分析
# 按照样本信息进行分组，其中3-5是DM，6-8是Ctrl
coldata <- data.frame(
    row.names = c("SRR21943973","SRR21943974","SRR21943975",
                  "SRR21943976","SRR21943977","SRR21943978"),
    condition = factor(c("DM","DM","DM","Ctrl","Ctrl","Ctrl"))
)
coldata # 查看分组情况
# 读入计数矩阵 + 构建 DESeq2 对象
library(DESeq2)
# 读入之前保存的矩阵（行名是第一列基因 ID）
counts <- as.matrix(read.csv("counts_matrix.csv", row.names = 1))
# 确保矩阵的列名与 coldata 的行名顺序一致
stopifnot(all(colnames(counts) == rownames(coldata)))
# 构建 DESeqDataSet
dds <- DESeqDataSetFromMatrix(countData = counts, colData = coldata, design = ~ condition)
# 过滤低表达基因（必须做）
# 保留至少在一半样本中 count ≥ 10 的基因
keep <- rowSums(counts(dds) >= 10) >= ncol(dds)/2
dds <- dds[keep,]
# 差异表达分析
dds <- DESeq(dds)
res <- results(dds, contrast = c("condition", "Ctrl", "DM"))
res <- res[order(res$padj), ]
head(res)
write.csv(as.data.frame(res), "DEG_results.csv")
# 结果可视化（快速质检）
# MA plot
plotMA(res, ylim = c(-5, 5))
# 样本聚类热图（用方差稳定转换后的数据）
vsd <- vst(dds, blind = FALSE)
plotPCA(vsd, intgroup = "condition")
# 筛选显著差异基因 + 功能富集
# 阈值：padj < 0.05 且 |log2FC| > 1
sig <- subset(res, padj < 0.05 & abs(log2FoldChange) > 1)
sig_genes <- rownames(sig)

# GO/KEGG 富集分析
library(clusterProfiler)
library(org.Mm.eg.db)   # 小鼠数据库
ego <- enrichGO(gene = sig_genes,
                OrgDb = org.Mm.eg.db,
                keyType = "ENSEMBL",
                ont = "BP",
                pAdjustMethod = "BH",
                qvalueCutoff  = 0.05)
head(ego)
dotplot(ego)
write.csv(ego@result, "GO_BP_enrichment.csv", row.names = FALSE)

# KEGG 通路富集（强烈推荐）
# KEGG 能解释差异基因在信号通路和代谢途径中的协同变化
# 把 ENSEMBL 转为 ENTREZ ID（KEGG 需要）
entrez_map <- AnnotationDbi::select(org.Mm.eg.db, keys = sig_genes, columns = "ENTREZID", keytype = "ENSEMBL")
# 报告'select()' returned 1:many mapping between keys and columns时说明某些 ENSEMBL ID 对应了多个 ENTREZ ID，仅为提示
# 去除没有 ENTREZ 的
entrez_map <- entrez_map[!is.na(entrez_map$ENTREZID), ]
# 去除一对多重复（保留第一个）
entrez_map <- entrez_map[!duplicated(entrez_map$ENSEMBL), ]
# 需要先下载好kegg_category.rda放到对应文件夹里
ekegg <- enrichKEGG(gene = entrez_map$ENTREZID, organism = "mmu", pAdjustMethod = "BH", qvalueCutoff = 0.05)
# 报错 URL 'https://yulab-smu.top/clusterProfiler/md5.txt': status was 'SSL connect error'无所谓
ekegg <- enrichKEGG(gene = sig_df$ENTREZID, organism = "mmu", pAdjustMethod = "BH", qvalueCutoff  = 0.05)
head(ekegg)
dotplot(ekegg)

# GSEA（基因集富集分析）
# GSEA 不依赖人为划分的显著基因阈值，能抓住协同微弱但一致的功能改变
# 准备排序的基因列表（按 log2FoldChange 降序）
res_ordered <- res[order(res$log2FoldChange, decreasing = TRUE), ]
geneList <- res_ordered$log2FoldChange
names(geneList) <- rownames(res_ordered)

# 转换 ID
geneList_entrez <- bitr(names(geneList), fromType = "ENSEMBL", toType = "ENTREZID", OrgDb = org.Mm.eg.db)
# 注意去重并保持顺序
geneList_entrez <- geneList_entrez[!duplicated(geneList_entrez$ENSEMBL), ]
# 构建命名数值向量
geneList_final <- geneList[geneList_entrez$ENSEMBL]
names(geneList_final) <- geneList_entrez$ENTREZID
# 去重 ENTREZ ID（每个 ENTREZ 只保留第一个值）
geneList_final_unique <- geneList_final[!duplicated(names(geneList_final))]
# 降序排列（GSEA 必需）
geneList_final_unique <- sort(geneList_final_unique, decreasing = TRUE)
# 确认没有重复
any(duplicated(names(geneList_final_unique)))  # 应该返回 FALSE

# GSEA GO
gsea_go <- gseGO(geneList = geneList_final_unique, OrgDb = org.Mm.eg.db, ont = "BP", minGSSize = 10, maxGSSize = 500, pAdjustMethod = "BH", verbose = FALSE)
dotplot(gsea_go)

# GSEA KEGG
gsea_kegg <- gseKEGG(geneList = geneList_final_unique, organism = "mmu", minGSSize = 10, maxGSSize = 500, pAdjustMethod = "BH",verbose = FALSE)
dotplot(gsea_kegg)
# GSEA 结果若出现 NES > 1.5 且 FDR < 0.05 的通路，通常有生物学意义
# 查看结果表的前几列，重点关注 NES 和 p.adjust
head(gsea_go@result[, c("Description", "NES", "pvalue", "p.adjust", "qvalue")])

# 筛选出 |NES| > 1.5 且 FDR < 0.05 的显著通路
sig_gsea <- gsea_go@result[abs(gsea_go@result$NES) > 1.5 & 
                           gsea_go@result$p.adjust < 0.05, ]
# 按 NES 绝对值排序
sig_gsea <- sig_gsea[order(-abs(sig_gsea$NES)), ]
head(sig_gsea[, c("Description", "NES", "p.adjust")])

# 可视化（替换默认 dotplot）
# 自定义气泡图（更美观）
library(ggplot2)
ego_df <- as.data.frame(ego)
# 将 GeneRatio 从 "X/Y" 转为数值
ego_df$GeneRatio_num <- sapply(ego_df$GeneRatio, function(x) eval(parse(text = x)))
# 气泡图
# 按校正后 p 值升序排序，取前 20 条
ego_top <- ego_df[order(ego_df$p.adjust), ][1:20, ]   # 数字可按需调整

ggplot(ego_top, aes(x = GeneRatio_num,
                    y = reorder(Description, GeneRatio_num),
                    size = Count,
                    color = p.adjust)) +
  geom_point() +
  scale_color_gradient(low = "red", high = "blue") +
  labs(x = "GeneRatio", y = "", size = "Count", color = "p.adjust") +
  theme_bw() +
  theme(axis.text.y = element_text(size = 9))  # 若标签仍多，可调小字号
ggsave("GO_bubble_top20.pdf", width = 8, height = 6)

# 富集网络图（看基因-通路联系）
enrichplot::cnetplot(ego, showCategory = 5, foldChange = geneList_final_unique)
ggsave("enrichplot.pdf", width = 8, height = 6)
